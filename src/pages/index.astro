---
import { marked } from 'marked';
import '../styles/global.css';

const MANIFESTO_URL =
  'https://raw.githubusercontent.com/reversegitops/manifesto/main/README.md';

const res = await fetch(MANIFESTO_URL);
if (!res.ok) {
  throw new Error(`Failed to fetch manifesto: ${res.status} ${res.statusText}`);
}
const raw = await res.text();

// Strip the H1 title — rendered in the hero
const body = raw.replace(/^#[^#].*\n/, '').trimStart();

let content = marked.parse(body) as string;

// Promote the closing statement to a pull-quote block
content = content.replace(
  /<p>The API comes first\. Git remembers\.<\/p>\s*<p>That is Reverse GitOps\.<\/p>/,
  `<div class="pull-quote">
    <p class="pull-main">The API comes first.<br>Git remembers.</p>
    <p class="pull-sub">That is Reverse GitOps.</p>
  </div>`
);

// Style the opening hook paragraph
content = content.replace(/<p>(GitOps gave us)/, '<p class="lead">$1');

const buildDate = new Date().toISOString().slice(0, 10);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reverse GitOps</title>
    <meta
      name="description"
      content="An API-first operating model where users and agents make validated changes through a typed platform API, while a controller writes those changes back into Git."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="hero">
      <div class="hero-glow"></div>
      <div class="hero-inner">
        <div class="wordmark">
          <span class="w-reverse">Reverse</span><span class="w-gitops">GitOps</span>
        </div>
        <p class="hero-tagline">API-first. Git-recorded. GitOps-compatible.</p>
        <a href="#manifesto" class="hero-cta">Read the manifesto ↓</a>
      </div>
    </div>

    <main id="manifesto">
      <article class="manifesto" set:html={content} />
    </main>

    <footer>
      <p>
        Content from <a
          href="https://github.com/reversegitops/manifesto"
          target="_blank"
          rel="noopener noreferrer">reversegitops/manifesto</a
        > &mdash; built {buildDate}
      </p>
    </footer>

  </body>
</html>
