---
import { marked } from 'marked';

const MANIFESTO_URL =
  'https://raw.githubusercontent.com/reversegitops/manifesto/main/README.md';

const res = await fetch(MANIFESTO_URL);
if (!res.ok) {
  throw new Error(`Failed to fetch manifesto: ${res.status} ${res.statusText}`);
}
const raw = await res.text();

// Strip the H1 title — we render it ourselves in the header
const body = raw.replace(/^#[^#].*\n/, '').trimStart();

const content = marked.parse(body);

const buildDate = new Date().toISOString().slice(0, 10);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reverse GitOps</title>
    <meta
      name="description"
      content="An API-first operating model where users and agents make validated changes through a typed platform API, while a controller writes those changes back into Git."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="wordmark">
          <span class="wordmark-reverse">Reverse</span><span class="wordmark-gitops">GitOps</span>
        </div>
        <p class="tagline">The API comes first. Git remembers.</p>
      </div>
    </header>

    <main>
      <article class="manifesto" set:html={content} />
    </main>

    <footer>
      <p>
        Content from <a
          href="https://github.com/reversegitops/manifesto"
          target="_blank"
          rel="noopener noreferrer">reversegitops/manifesto</a
        > &mdash; built {buildDate}
      </p>
    </footer>

    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #0d1117;
        --surface: #161b22;
        --border: #30363d;
        --text: #e6edf3;
        --muted: #8b949e;
        --accent: #58a6ff;
        --accent-dim: #1f3a5f;
        --green: #3fb950;
        --font-sans: 'Inter', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
        --max-w: 740px;
      }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ── Header ── */
      header {
        border-bottom: 1px solid var(--border);
        padding: 3rem 1.5rem 2.5rem;
      }

      .header-inner {
        max-width: var(--max-w);
        margin: 0 auto;
      }

      .wordmark {
        font-family: var(--font-mono);
        font-size: clamp(2rem, 6vw, 3.25rem);
        font-weight: 500;
        letter-spacing: -0.03em;
        line-height: 1;
        margin-bottom: 1rem;
      }

      .wordmark-reverse {
        color: var(--muted);
      }

      .wordmark-gitops {
        color: var(--accent);
      }

      .tagline {
        font-size: 1.1rem;
        color: var(--muted);
        font-style: italic;
      }

      /* ── Main ── */
      main {
        flex: 1;
        padding: 3rem 1.5rem;
      }

      .manifesto {
        max-width: var(--max-w);
        margin: 0 auto;
      }

      /* Markdown content styles */
      .manifesto h2 {
        font-size: 1.35rem;
        font-weight: 600;
        color: var(--text);
        margin-top: 3rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--border);
        letter-spacing: -0.01em;
      }

      .manifesto h2:first-child {
        margin-top: 0;
      }

      .manifesto p {
        color: #c9d1d9;
        margin-bottom: 1rem;
      }

      .manifesto hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2.5rem 0;
      }

      .manifesto strong {
        color: var(--text);
        font-weight: 600;
      }

      .manifesto em {
        color: var(--muted);
      }

      .manifesto a {
        color: var(--accent);
        text-decoration: none;
      }

      .manifesto a:hover {
        text-decoration: underline;
      }

      /* Table */
      .manifesto table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.9rem;
      }

      .manifesto th {
        background: var(--surface);
        color: var(--text);
        font-weight: 600;
        text-align: left;
        padding: 0.6rem 1rem;
        border: 1px solid var(--border);
      }

      .manifesto td {
        padding: 0.6rem 1rem;
        border: 1px solid var(--border);
        color: #c9d1d9;
        vertical-align: top;
      }

      .manifesto tr:nth-child(even) td {
        background: #0f1318;
      }

      /* Blockquote / callout-style principle blocks */
      .manifesto blockquote {
        border-left: 3px solid var(--accent);
        padding: 0.75rem 1.25rem;
        margin: 1.5rem 0;
        background: var(--accent-dim);
        border-radius: 0 6px 6px 0;
      }

      .manifesto code {
        font-family: var(--font-mono);
        font-size: 0.875em;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.1em 0.4em;
      }

      /* ── Footer ── */
      footer {
        border-top: 1px solid var(--border);
        padding: 1.5rem;
        text-align: center;
        color: var(--muted);
        font-size: 0.85rem;
      }

      footer a {
        color: var(--accent);
        text-decoration: none;
      }

      footer a:hover {
        text-decoration: underline;
      }

      @media (max-width: 600px) {
        .manifesto table {
          font-size: 0.8rem;
        }

        .manifesto th,
        .manifesto td {
          padding: 0.5rem 0.6rem;
        }
      }
    </style>
  </body>
</html>
